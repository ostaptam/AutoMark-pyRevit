<Window
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="AutoMark"
    Width="410"
    Height="280"
    WindowStartupLocation="CenterScreen"
    ResizeMode="NoResize"
    Background="#252525">

    <Window.Resources>
        <Style TargetType="Button">
            <Setter Property="Height" Value="42"/>
            <Setter Property="Margin" Value="0,0,0,10"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Background" Value="#E6E6E6"/>
            <Setter Property="Foreground" Value="#111111"/>
            <Setter Property="BorderBrush" Value="#C8C8C8"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>
    </Window.Resources>

    <Border
        Margin="14"
        Padding="18"
        Background="#303030"
        CornerRadius="8"
        BorderBrush="#444444"
        BorderThickness="1">

        <StackPanel>

            <TextBlock
                Text="AutoMark"
                FontSize="21"
                FontWeight="SemiBold"
                Foreground="#FFFFFF"
                Margin="0,0,0,4"/>

            <TextBlock
                Text="Door and window numbering tool"
                FontSize="12"
                Foreground="#B8B8B8"
                Margin="0,0,0,18"/>

            <Border
                Background="#292929"
                BorderBrush="#4A4A4A"
                BorderThickness="1"
                CornerRadius="6"
                Padding="12"
                Margin="0,0,0,16">

                <TextBlock
                    Text="This tool will overwrite Mark values and renumber doors and windows by level and coordinates."
                    Foreground="#D0D0D0"
                    FontSize="12"
                    TextWrapping="Wrap"/>
            </Border>

            <Button
                x:Name="btn_run"
                Content="Run AutoMark"/>

            <Button
                x:Name="btn_cancel"
                Content="Cancel"
                Background="#3A3A3A"
                Foreground="#F2F2F2"
                BorderBrush="#555555"/>

        </StackPanel>
    </Border>
</Window>